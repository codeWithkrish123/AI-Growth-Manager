# AI Growth Manager Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port for the backend server to listen on
PORT=3001

# Environment mode (development, production, test)
NODE_ENV=development

# Frontend application URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Full PostgreSQL connection URI (preferred method)
POSTGRES_URI=postgresql://username:password@localhost:5432/ai_growth_manager

# Alternative: Individual database connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_NAME=ai_growth_manager

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Redis connection URL for job queues and caching
REDIS_URL=redis://localhost:6379

# ============================================================================
# SHOPIFY CONFIGURATION
# ============================================================================
# Shopify Partner App credentials (get from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Required Shopify API scopes (comma-separated, no spaces)
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_checkouts,read_price_rules,write_price_rules,read_discounts

# Your app's public URL (for OAuth callbacks and webhooks)
APP_URL=https://your-app-url.ngrok.io

# Shopify webhook secret for signature verification
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================
# Google OAuth credentials (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google OAuth redirect URI (must match Google Cloud Console configuration)
GOOGLE_REDIRECT_URI=http://localhost:3001/google/auth/google/callback

# ============================================================================
# SECURITY & ENCRYPTION
# ============================================================================
# JWT secret for token signing (minimum 32 characters, use random string)
JWT_SECRET=your_super_secure_jwt_secret_key_minimum_32_chars

# Encryption key for sensitive data (exactly 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key_here

# ============================================================================
# AI CONFIGURATION
# ============================================================================
# AI service provider (openai or anthropic)
AI_PROVIDER=openai

# OpenAI API key (get from OpenAI dashboard)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic API key (alternative to OpenAI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI model to use for analysis
AI_MODEL=gpt-4o-mini

# ============================================================================
# BACKGROUND JOB SCHEDULING
# ============================================================================
# Cron expression for data synchronization (every hour by default)
SYNC_CRON=0 */1 * * *

# Cron expression for health snapshots (daily at midnight by default)
HEALTH_SNAPSHOT_CRON=0 0 * * *

# ============================================================================
# EMAIL CONFIGURATION (Resend)
# ============================================================================
# Get free API key: https://resend.com -> Dashboard -> API Keys
RESEND_API_KEY=re_your_resend_api_key_here
#
# SANDBOX (free, works immediately):
#    EMAIL_FROM=Your Store Name <onboarding@resend.dev>
#    Emails show onboarding@resend.dev as sender
#
# PRODUCTION (after verifying domain in Resend):
#    EMAIL_FROM=Your Store Name <hello@yourdomain.com>
EMAIL_FROM=AI Growth Manager <onboarding@resend.dev>


# ============================================================================
# OPTIONAL DEVELOPMENT VARIABLES
# ============================================================================
SHOP_NAME=your-test-shop.myshopify.com
AI_GROWTH_MANAGER_KEY=aigrowthmanager-secret-key-2024

# ============================================================================
# GOOGLE PAGESPEED API (free, no billing required)
# Get key: https://console.cloud.google.com → APIs → PageSpeed Insights API → Credentials
# ============================================================================
GOOGLE_PAGESPEED_API_KEY=your_pagespeed_api_key_here