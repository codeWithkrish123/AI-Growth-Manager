# AI Growth Manager Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# Database Configuration
POSTGRES_URI=postgresql://username:password@localhost:5432/ai_growth_manager

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Shopify Configuration
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_products
APP_URL=https://your-app-url.ngrok.io

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key_here

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
AI_MODEL=gpt-4o-mini

# Cron Jobs
SYNC_CRON=0 */1 * * *
HEALTH_SNAPSHOT_CRON=0 0 * * *