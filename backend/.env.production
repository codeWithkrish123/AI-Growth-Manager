# Production Environment Variables
NODE_ENV=production
PORT=3001

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=https://your-vercel-app.vercel.app

# Shopify Configuration
SHOPIFY_API_KEY=your_production_api_key
SHOPIFY_API_SECRET=your_production_api_secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_checkouts,read_price_rules,write_price_rules,read_discounts
APP_URL=https://your-backend-url.com

# Shopify Webhook Secret
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# Database Configuration (PostgreSQL - e.g., Neon, Supabase, AWS RDS)
POSTGRES_URI=postgresql://user:password@host:5432/ai_growth_manager
DB_HOST=your-db-host
DB_PORT=5432
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=ai_growth_manager

# Redis Configuration (e.g., Upstash, Redis Cloud)
REDIS_URL=redis://your-redis-host:6379

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-backend-url.com/google/auth/google/callback

# Security (generate with: openssl rand -hex 32 | head -c 32)
JWT_SECRET=your_production_jwt_secret_min_32_chars_long
ENCRYPTION_KEY=your_32_character_encryption_key_

# AI Configuration
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=gpt-4o-mini

# Email Configuration (Resend - get free API key at resend.com)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=AI Growth Manager <onboarding@resend.dev>

# Background Job Scheduling
SYNC_CRON=0 */1 * * *
HEALTH_SNAPSHOT_CRON=0 0 * * *

# AI Growth Manager Internal Key
AI_GROWTH_MANAGER_KEY=your_internal_service_key_here

